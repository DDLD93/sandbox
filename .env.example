# --- Transcriber configuration -------------------------------------------
# Copy to .env (used by `npm run dev`, which loads it via --env-file=.env).
# The download feature needs none of these; only the transcriber does.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# PostgreSQL — either a single URL...
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/transcriber
# ...or the discrete libpq vars (used if DATABASE_URL is unset):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=transcriber

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=transcriber

# HTTP server (optional)
# HOST=127.0.0.1
# PORT=8000
